<style>
.like-form {
    display: inline-block;
    margin-top: 10px;
}

.like-btn {
    background: linear-gradient(135deg, #ff4d6d, #ff758f);
    border: none;
    color: white;
    padding: 10px 18px;
    font-size: 14px;
    font-weight: 600;
    border-radius: 25px;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 12px rgba(255, 77, 109, 0.3);
}

.like-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(255, 77, 109, 0.45);
}

.like-btn:active {
    transform: scale(0.95);
}
</style>

<form action="/like/<%= product._id %>" method="POST" class="like-form">
    <button type="submit" class="like-btn">
        Like (<%= product.likes || 0 %>)
    </button>
</form>